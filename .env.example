MONGODB_URI=mongodb://127.0.0.1:27017/smartschool
APP_URL=http://localhost:3000
NODE_ENV=development

# Shared secret required to seed the first Admin account via POST /api/auth/seed-admin.
# Generate a random string for this - it is not the Admin's password.
SEED_SECRET=

# Signs the session cookie so it can't be forged/tampered with. Must be 32+ random characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
